<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 通讯录白名单 -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <!-- 识别来电号码 -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <!-- 备选挂断方案 / 部分机型拨号能力 -->
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.ANSWER_PHONE_CALLS" />

    <!-- 拦截日志通知（可选） -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".HangupPhoneApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.HangupPhone">

        <activity
            android:name=".ui.SetupActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.MainActivity"
            android:exported="false"
            android:launchMode="singleTop" />

        <!--
            核心：CallScreeningService
            用户必须将本应用设为「默认来电筛选应用」后才会被系统回调。
            android:permission 限制只有系统 Telecom 框架可绑定。
        -->
        <service
            android:name=".service.MyCallScreeningService"
            android:exported="true"
            android:permission="android.permission.BIND_SCREENING_SERVICE">
            <intent-filter>
                <action android:name="android.telecom.CallScreeningService" />
            </intent-filter>
        </service>

    </application>

</manifest>
